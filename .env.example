APP_NAME="U-Mail"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=https://u-mail.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=utica_mail
DB_USERNAME=utica_mail
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
EXTERNAL_MAIL_QUEUE=external-mail
CRITICAL_MAIL_QUEUE=critical-mail

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@u-mail.local"
MAIL_FROM_NAME="${APP_NAME}"
PUBLIC_MAIL_DOMAIN=u-mail.local
MAIL_MESSAGE_ID_DOMAIN=u-mail.local
MAILCOW_ENABLED=false
MAX_INCOMING_MAIL_BYTES=31457280
MAX_INCOMING_ATTACHMENT_BYTES=26214400

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OWNER_EMAIL=
ADMIN_LOGIN_PATH=utica-admin-entry
ADMIN_IDLE_MINUTES=15
PASSWORD_CONFIRMATION_SECONDS=300
SECURITY_AUDIT_RETENTION_DAYS=180
MFA_ISSUER="U-Mail"
AI_FEATURES_ENABLED=false
AI_PROVIDER=none
AI_LOCAL_ENDPOINT=http://127.0.0.1:11434
AI_LOCAL_MODEL=llama3.2
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_FAILURE_THRESHOLD=3
REGISTRATION_ENABLED=true
